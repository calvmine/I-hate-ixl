{
  "manifest_version": 3,
  "name": "IXL Auto Solver",
  "version": "1.0.0",
  "description": "Automatically solves IXL math problems",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.ixl.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "IXL Auto Solver"
  },
  "content_scripts": [
    {
      "matches": ["https://www.ixl.com/*"],
      "js": ["solver.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
